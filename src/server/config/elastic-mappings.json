          "type": "object",
          "properties": {
            "date": { "type": "date" },
            "agenda": { "type": "text" },
            "attendees": { "type": "keyword" }
          }
        },
        "tags": { "type": "keyword" },
        "meeting_type": { "type": "keyword" },
        "sales_stage": { "type": "keyword" },
