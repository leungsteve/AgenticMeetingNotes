            "committed_by": { "type": "keyword" },
            "timeline": { "type": "text" }
          }
        },
        "customer_sentiment": {
          "type": "object",
          "properties": {
            "overall": { "type": "keyword" },
            "concerns": { "type": "text" },
            "objections": { "type": "text" },
            "champion_signals": { "type": "text" }
          }
        },
        "competitive_landscape": {
          "type": "object",
          "properties": {
            "incumbent": { "type": "text" },
