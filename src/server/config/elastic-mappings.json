        "meeting_purpose": { "type": "text" },
        "scheduled_by": { "type": "keyword" },
        "title": {
          "type": "text",
          "fields": { "keyword": { "type": "keyword" } }
        },
        "summary": { "type": "text" },
        "transcript": { "type": "text" },
        "key_topics": { "type": "text" },
        "decisions_made": { "type": "text" },
        "open_questions": { "type": "text" },
