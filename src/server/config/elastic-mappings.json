          "type": "object",
          "properties": {
            "enthusiastic": { "type": "integer" },
            "positive": { "type": "integer" },
            "neutral": { "type": "integer" },
            "cautious": { "type": "integer" },
            "concerned": { "type": "integer" },
            "skeptical": { "type": "integer" }
          }
        },
        "latest_sentiment": { "type": "keyword" },
        "tags_frequency": { "type": "object", "enabled": false },
        "meeting_types": { "type": "keyword" },
        "authors": { "type": "keyword" },
        "momentum_score": { "type": "float" },
        "computed_at": { "type": "date" }
      }
    }
  },
  "action-items": {
    "mappings": {
      "properties": {
        "source_note_id": { "type": "keyword" },
        "account": { "type": "keyword" },
        "meeting_date": { "type": "date" },
        "meeting_title": { "type": "text", "fields": { "keyword": { "type": "keyword" } } },
