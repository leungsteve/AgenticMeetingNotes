        "owner": { "type": "keyword" },
        "due_date": { "type": "date" },
        "status": { "type": "keyword" },
        "ingested_at": { "type": "date" }
      }
    }
  },
  "agent-actions": {
    "mappings": {
      "properties": {
        "tool_name": { "type": "keyword" },
        "acting_user": { "type": "keyword" },
        "input": { "type": "object", "enabled": false },
