  "granola-sync-state": {
    "mappings": {
      "properties": {
        "user_email": { "type": "keyword" },
        "user_name": { "type": "keyword" },
        "user_role": { "type": "keyword" },
        "last_fetched_at": { "type": "date" },
        "last_fetched_cursor": { "type": "keyword" },
        "total_notes_fetched": { "type": "integer" },
        "total_notes_ingested": { "type": "integer" },
        "granola_api_key": { "type": "keyword", "index": false, "doc_values": false }
      }
    }
  },
  "granola-lookups": {
    "mappings": {
      "properties": {
        "type": { "type": "keyword" },
        "value": { "type": "keyword" },
        "label": { "type": "text" },
        "metadata": { "type": "object", "enabled": false }
      }
    }
  },
