# Elastic Serverless — see "Elastic Serverless Setup Guide" in PROJECT_BRIEF.md for how to obtain these
# ELASTIC_CLOUD_ID may be your Cloud ID (name:base64…) OR the cluster HTTPS URL from the Elastic Cloud UI
ELASTIC_CLOUD_ID=your-cloud-id
ELASTIC_API_KEY=your-api-key
# Granola (optional for local scripts; per-user keys are stored in Elastic — see Settings)
# GRANOLA_API_BASE=https://public-api.granola.ai
# GRANOLA_API_KEY=grn_...
# Local Google Drive path — see "Google Drive for Desktop Setup" in PROJECT_BRIEF.md
DRIVE_NOTES_PATH=/Users/you/Library/CloudStorage/GoogleDrive-you@company.com/Shared drives/Account Teams
# Jina AI API key — for Elastic Inference Service (EIS) endpoints
# Get from: https://jina.ai/api-key
# Optional: if not set, EIS endpoints will be skipped and BM25+ELSER fallback is used
JINA_API_KEY=
# Elastic Agent Builder endpoint (Phase 2)
AGENT_BUILDER_URL=
AGENT_BUILDER_API_KEY=
