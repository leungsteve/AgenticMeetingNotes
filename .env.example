# Elastic Serverless — see "Elastic Serverless Setup Guide" in PROJECT_BRIEF.md for how to obtain these
# ELASTIC_CLOUD_ID may be your Cloud ID (name:base64…) OR the cluster HTTPS URL from the Elastic Cloud UI
ELASTIC_CLOUD_ID=your-cloud-id
ELASTIC_API_KEY=your-api-key
# Granola (optional for local scripts; per-user keys are stored in Elastic — see Settings)
# GRANOLA_API_BASE=https://public-api.granola.ai
# GRANOLA_API_KEY=grn_...
# Local Google Drive path — see "Google Drive for Desktop Setup" in PROJECT_BRIEF.md
DRIVE_NOTES_PATH=/Users/you/Library/CloudStorage/GoogleDrive-you@company.com/Shared drives/Account Teams
# Jina AI API key — for Elastic Inference Service (EIS) endpoints
# Get from: https://jina.ai/api-key
# Optional: if not set, EIS endpoints will be skipped and BM25+ELSER fallback is used
JINA_API_KEY=
# Elastic Agent Builder endpoint (Phase 2)
AGENT_BUILDER_URL=
AGENT_BUILDER_API_KEY=

# --- Multi-user auth (Phase 1) ---
# Google OIDC client (create at https://console.cloud.google.com/apis/credentials → "OAuth client ID" → Web application).
# Authorized redirect URI must match GOOGLE_OIDC_REDIRECT_URI exactly.
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
GOOGLE_OIDC_REDIRECT_URI=http://localhost:3001/auth/google/callback
# Lock sign-in to one Google Workspace domain (e.g. yourcompany.com). Comma-separated for multiple.
ALLOWED_HD=
# Where the SPA lives — used to redirect back after login and to lock CORS in multi-user mode.
APP_ORIGIN=http://localhost:5173
# Secret for signing the session cookie. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=
# Comma-separated emails that bypass scope filters (admin role). Optional.
ADMIN_EMAILS=
# Master key for encrypting per-user Granola API keys at rest (32 bytes base64). Generate with the same command as SESSION_SECRET.
MASTER_ENCRYPTION_KEY=
# Set to "true" to enable multi-user enforcement (requireUser middleware, scope filters, encrypted keys).
# Leave unset/false during local dev to keep the legacy single-user flow working.
MULTI_USER=false
